{
  "name": "@ayco/astro-sw",
  "author": "Ayo Ayco",
  "license": "MIT",
  "version": "0.10.0",
  "repository": {
    "type": "git",
    "url": "https://git.ayo.run/ayo/astro-sw"
  },
  "description": "Use your own authored service worker with Astro",
  "exports": {
    ".": {
      "types": "./dist/astro-sw.d.ts",
      "default": "./dist/astro-sw.js"
    },
    "./globals": {
      "types": "./dist/eslint/globals.d.ts",
      "default": "./dist/eslint/globals.js"
    },
    "./presets": {
      "types": "./dist/presets/index.d.ts",
      "default": "./dist/presets/index.js"
    },
    "./presets/*": {
      "types": "./dist/presets/*/index.d.ts",
      "default": "./dist/presets/*/index.js"
    },
    "./package.json": {
      "default": "./package.json"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "main": "./astro-sw.js",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup src/astro-sw.ts src/presets/index.ts src/presets/**/index.ts src/eslint/globals.ts --format esm --dts --clean && cp ../README.md .",
    "test": "vitest run",
    "bump": "bumpp",
    "publish": "npm publish",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major"
  },
  "keywords": [
    "withastro",
    "perf"
  ],
  "dependencies": {
    "esbuild": "^0.27.4"
  },
  "peerDependencies": {
    "astro": "^6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "bumpp": "^11.0.1"
  }
}
